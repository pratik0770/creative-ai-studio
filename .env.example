# ─── App ─────────────────────────────────────────────────────────
APP_NAME=Creative AI Studio
DEBUG=true
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ─── GCP Project ─────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ─── Cloud SQL (PostgreSQL) ───────────────────────────────────────
# Local development: direct connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=creative_ai_studio
DB_USER=postgres
DB_PASSWORD=your-db-password

# Production: Cloud SQL instance connection name (project:region:instance)
CLOUD_SQL_INSTANCE=your-project:us-central1:creative-ai-studio-db

# ─── Firebase / Google Identity Platform ─────────────────────────
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# Path to your Firebase Admin SDK service account JSON (local dev only)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ─── Google Cloud Storage ─────────────────────────────────────────
GCS_BUCKET=your-bucket-name

# ─── Vertex AI ───────────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1

# ─── Flask Session ────────────────────────────────────────────────
SESSION_TYPE=filesystem
SESSION_PERMANENT=false
PERMANENT_SESSION_LIFETIME=3600
